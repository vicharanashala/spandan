# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and email reset links)
# Include the base path if using one (e.g., http://localhost:5173/spandan OR https://your-domain.com/spandan)
FRONTEND_URL=http://localhost:5173/spandan

# CORS allowed origins (comma-separated, no paths)
# For local dev: http://localhost:5173,http://localhost:3001,http://localhost:8080
# For production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:8080

# MongoDB
MONGODB_URI=mongodb://localhost:27017/spandan

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-string-here

# AI Provider API Keys for Question Generation
MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# SMTP Email Configuration (for password reset & welcome emails)
# Using Gmail SMTP - enable 2FA and use App Password as SMTP_PASSWORD
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Optional: Resend API Key (alternative to Gmail SMTP)
RESEND_API_KEY=
